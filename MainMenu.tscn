[node name="DifficultyBtnRight" type="Button" parent="MainMenu/DifficultyContainer"]
layout_mode = 2
custom_minimum_size = Vector2(60, 50)
text = ">>"

[node name="StartBtn" type="Button" parent="MainMenu"]
