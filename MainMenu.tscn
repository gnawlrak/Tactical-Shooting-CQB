[gd_scene load_steps=4 format=3]

[ext_resource type="Script" path="res://MainMenu.gd" id="1_script"]
[ext_resource type="Shader" path="res://blur.gdshader" id="2_shader"]
[ext_resource type="PackedScene" path="res://MapBackground.tscn" id="3_map"]

[sub_resource type="ShaderMaterial" id="ShaderMaterial_blur"]
shader = ExtResource("2_shader")
shader_parameter/blur_amount = 3.0

[sub_resource type="LabelSettings" id="LabelSettings_title"]
font_size = 64

[sub_resource type="LabelSettings" id="LabelSettings_btn"]
font_size = 24

[node name="MainMenuScene" type="Control"]
layout_mode = 3
anchors_preset = 15
anchor_right = 1.0
anchor_bottom = 1.0
grow_horizontal = 2
grow_vertical = 2
script = ExtResource("1_script")

[node name="Background3D" type="SubViewportContainer" parent="."]
layout_mode = 1
anchors_preset = 15
anchor_right = 1.0
anchor_bottom = 1.0
stretch = true

[node name="SubViewport" type="SubViewport" parent="Background3D"]
size = Vector2i(640, 360)

[node name="MapScene" parent="Background3D/SubViewport" instance=ExtResource("3_map")]

[node name="BlurOverlay" type="ColorRect" parent="."]
layout_mode = 1
anchors_preset = 15
anchor_right = 1.0
anchor_bottom = 1.0
material = SubResource("ShaderMaterial_blur")

[node name="Title" type="Label" parent="."]
layout_mode = 1
anchors_preset = 10
anchor_right = 1.0
offset_top = 30.0
offset_bottom = 100.0
text = "战术射击"
horizontal_alignment = 1
label_settings = SubResource("LabelSettings_title")

[node name="MainMenu" type="VBoxContainer" parent="."]
layout_mode = 1
anchors_preset = 8
anchor_left = 0.5
anchor_top = 0.5
anchor_right = 0.5
anchor_bottom = 0.5
offset_left = -200.0
offset_top = -160.0
offset_right = 200.0
offset_bottom = 160.0
theme_override_constants/separation = 20

[node name="DifficultyContainer" type="HBoxContainer" parent="MainMenu"]
layout_mode = 2
custom_minimum_size = Vector2(0, 50)

[node name="DifficultyBtnLeft" type="Button" parent="MainMenu/DifficultyContainer"]
layout_mode = 2
custom_minimum_size = Vector2(60, 50)
text = "<<"

[node name="DifficultyLabel" type="Label" parent="MainMenu/DifficultyContainer"]
