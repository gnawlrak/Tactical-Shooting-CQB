[gd_scene load_steps=3 format=3]

[ext_resource type="Script" path="res://PauseMenu.gd" id="1_script"]
[ext_resource type="Shader" path="res://blur.gdshader" id="2_shader"]

[sub_resource type="ShaderMaterial" id="ShaderMaterial_blur"]
shader = ExtResource("2_shader")
shader_parameter/blur_amount = 5.0

[sub_resource type="LabelSettings" id="LabelSettings_title"]
font_size = 48

[sub_resource type="LabelSettings" id="LabelSettings_btn"]
font_size = 28

[node name="PauseMenuCanvas" type="CanvasLayer"]
layer = 100
script = ExtResource("1_script")

[node name="BlurOverlay" type="ColorRect" parent="."]
visible = false
layout_mode = 1
anchors_preset = 15
anchor_right = 1.0
anchor_bottom = 1.0
material = SubResource("ShaderMaterial_blur")

[node name="PauseMenu" type="VBoxContainer" parent="."]
visible = false
layout_mode = 1
anchors_preset = 8
anchor_left = 0.5
anchor_top = 0.5
anchor_right = 0.5
anchor_bottom = 0.5
offset_left = -150.0
offset_top = -150.0
offset_right = 150.0
offset_bottom = 150.0
theme_override_constants/separation = 20

[node name="Title" type="Label" parent="PauseMenu"]
layout_mode = 2
text = "暂停"
horizontal_alignment = 1
label_settings = SubResource("LabelSettings_title")

[node name="ResumeBtn" type="Button" parent="PauseMenu"]
layout_mode = 2
custom_minimum_size = Vector2(0, 50)
text = "继续游戏"
label_settings = SubResource("LabelSettings_btn")

[node name="MainMenuBtn" type="Button" parent="PauseMenu"]
layout_mode = 2
custom_minimum_size = Vector2(0, 50)
text = "返回主菜单"
label_settings = SubResource("LabelSettings_btn")

[node name="QuitBtn" type="Button" parent="PauseMenu"]
layout_mode = 2
custom_minimum_size = Vector2(0, 50)
text = "退出游戏"
label_settings = SubResource("LabelSettings_btn")

[connection signal="pressed" from="PauseMenu/ResumeBtn" to="." method="_on_resume_pressed"]
[connection signal="pressed" from="PauseMenu/MainMenuBtn" to="." method="_on_main_menu_pressed"]
[connection signal="pressed" from="PauseMenu/QuitBtn" to="." method="_on_quit_pressed"]
